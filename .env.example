# Neon Postgres — crie em neon.tech, copie a connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# URL do site em produção (para revalidate após pipeline)
SITE_URL=https://www.jdmarket.ai

# Segredo para o endpoint /api/revalidate (qualquer string longa)
REVALIDATE_SECRET=seu_segredo_aqui_32chars_minimo

# APIs do pipeline B3 (necessárias apenas no GitHub Actions, não no Next.js)
ANTHROPIC_KEY=sk-ant-...
HG_KEY=...
BRAPI_TOKEN=...
